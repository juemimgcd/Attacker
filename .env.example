APP__APP_NAME=attacker
APP__APP_ENV=local
APP__DEBUG=true
APP__API_PREFIX=

LOG__LOG_LEVEL=INFO
LOG__LOG_DIR=logs
LOG__LOG_ROTATION=10 MB
LOG__LOG_RETENTION=14 days

AGENT__PROVIDER=qwen
AGENT__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
